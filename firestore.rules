rules_version = '2';

// Ces règles exigent qu'un visiteur soit connecté (email/mot de passe,
// via Firebase Authentication) pour lire ou écrire quoi que ce soit dans
// la base. Le script collect.js (GitHub Actions) utilise une clé de
// compte de service Admin qui CONTOURNE ces règles — il continue donc de
// fonctionner même sans connexion utilisateur, comme demandé.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
